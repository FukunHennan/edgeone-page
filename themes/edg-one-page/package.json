{
  "name": "edg-one-page",
  "version": "1.0.0",
  "private": false,
  "description": "EdgeOne Page theme for Hexo.",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "npx @tailwindcss/cli -i source/css/tailwind.source.css -o source/css/build/tailwind.css --minify",
    "build:js": "node source/js/build.js",
    "watch:css": "npx @tailwindcss/cli -i source/css/tailwind.source.css -o source/css/build/tailwind.css --watch --minify",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitee.com/chenfukun/edg-one-page.git"
  },
  "keywords": [
    "hexo",
    "theme",
    "edgeone",
    "onepage",
    "simple",
    "hexo-theme"
  ],
  "author": "chenfukun",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://gitee.com/chenfukun/edg-one-page/issues"
  },
  "homepage": "https://gitee.com/chenfukun/edg-one-page",
  "devDependencies": {
    "eslint": "^8.47.0",
    "glob-promise": "^6.0.7",
    "husky": "^9.1.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.1.11",
    "terser": "^5.36.0"
  }
}
