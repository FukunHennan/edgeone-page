{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "description": "A Simplified Chinese and English Hexo site optimized for Tencent EdgeOne Pages.",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('public',{recursive:true,force:true});require('fs').rmSync('db.json',{force:true})\"",
    "build": "npm run build:production",
    "build:production": "node tools/build-bilingual.js",
    "audit:production": "node tools/audit-production.js",
    "check": "node tools/validate-bilingual.js && npm run build:production && npm run audit:production",
    "check:content": "node tools/validate-bilingual.js",
    "new:post": "node tools/new-bilingual-post.js",
    "server": "npm run server:zh-CN",
    "server:zh-CN": "hexo server --config _config.yml,_config.zh-CN.yml",
    "server:en": "hexo server --config _config.yml,_config.en.yml",
    "deploy": "hexo deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FukunHennan/edgeone-page.git"
  },
  "bugs": {
    "url": "https://github.com/FukunHennan/edgeone-page/issues"
  },
  "homepage": "https://github.com/FukunHennan/edgeone-page#readme",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "hexo": "^8.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-landscape": "^1.0.0",
    "hexo-wordcount": "^6.0.1",
    "js-yaml": "^4.1.1"
  }
}
